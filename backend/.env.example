# Model weights paths
YOLO_CONF_THRESHOLD=0.25
YOLO_WEIGHTS_PATH=./weights/yolov8n.pt
RCNN_WEIGHTS_PATH=./weights/rcnn_coco.pt
ONNX_QUALITY_MODEL=./weights/quality_classifier.onnx

# Celery / Redis
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO or AWS S3)
S3_BUCKET=kyc-captures
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# JWT (for frontend test sessions)
JWT_SECRET=change_me_in_production
ALLOWED_ORIGINS=*

# Database
DATABASE_URL=sqlite:///./kyc.db
PG_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/kyc

# Encryption key for captures (32 bytes hex)
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# API keys for service-to-service calls (comma-separated)
API_KEYS=your_production_api_key_here,test_key_123
